# Calendar Sync — OAuth client IDs for Google and Microsoft
# Create a Google Cloud project -> APIs & Services -> Credentials -> OAuth 2.0 Client ID (Desktop app).
# For Azure: App registrations -> New registration -> Public client/native (mobile & desktop).
# Both providers accept http://localhost (any port) as a redirect URI for desktop apps.
VITE_GOOGLE_CLIENT_ID=
VITE_MICROSOFT_CLIENT_ID=
