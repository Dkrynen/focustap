{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FocusTap",
  "version": "0.1.0",
  "identifier": "com.focustap.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FocusTap",
        "label": "main",
        "width": 420,
        "height": 560,
        "decorations": true,
        "visible": true,
        "center": true,
        "resizable": true,
        "minWidth": 380,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": ["https://api.github.com/repos/YOUR_USERNAME/focustap/releases/latest"],
      "pubkey": "YOUR_PUBLIC_KEY_HERE"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
