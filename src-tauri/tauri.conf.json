{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FocusTap",
  "version": "0.1.0",
  "identifier": "com.focustap.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FocusTap",
        "label": "main",
        "width": 420,
        "height": 560,
        "decorations": true,
        "visible": true,
        "center": true,
        "resizable": true,
        "minWidth": 380,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data:; font-src 'self'; connect-src 'self'"
    }
  },
  "plugins": {
    "licenseseat": {
      "apiKey": "pk_test_placeholder",
      "productSlug": "focustap"
    },
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": ["https://api.github.com/repos/Dkrynen/focustap/releases/latest"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5RTUxNDQ0OEFEREUwRTIKUldUaTROMktSQlRsK1poZG1lQm9MWU1kdXpkN09NM3lVMDJEaXZXNFg5QWE4aGJWYkw4QTVvay8K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
